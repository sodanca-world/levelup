---
import siteData from '../data/siteData.json';
import GoogleTagManager from '../components/GoogleTagManager.astro';
import '../styles/global.css';

interface Props {
  lang: 'portugues' | 'english' | 'espanol' | 'france' | 'italia' | 'latin-america';
}

const { lang } = Astro.props;
const data = siteData.idiomas[lang];
const { configuracoes } = siteData;

const title = data.seo.titulo || `Só Dança - Level Up`;
const description = data.seo.descricao;
const canonical = Astro.url.href;

// Configuração de SEO Geográfico
const geoRegion = data.seo.regiao;
const geoPlacename = data.seo.cidade;
const geoPosition = data.seo.coordenadas;

// Schema LocalBusiness para AEO
const businessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "SportsGoodsStore"],
  "@id": `${configuracoes.empresa_site_base}/#business`,
  "name": configuracoes.empresa_nome,
  "url": configuracoes.empresa_site_base,
  "logo": `${configuracoes.empresa_site_base}/assets/images/${configuracoes.empresa_logo_imagem}`,
  "description": description,
  "email": configuracoes.empresa_email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": geoPlacename,
    "addressRegion": geoRegion.split("-")[1] || geoRegion,
    "addressCountry": geoRegion.split("-")[0]
  }
};
---

<!DOCTYPE html>
<html lang={lang === 'portugues' ? 'pt-BR' : lang === 'espanol' || lang === 'latin-america' ? 'es' : lang === 'france' ? 'fr' : lang === 'italia' ? 'it' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- GEO-targeting -->
    <meta name="geo.region" content={geoRegion} />
    <meta name="geo.placename" content={geoPlacename} />
    <meta name="geo.position" content={geoPosition} />
    <meta name="ICBM" content={geoPosition.replace(';', ', ')} />

    <!-- Speakable Specification (AEO) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SpeakableSpecification",
        "cssSelector": [".hero-desc", ".why-text", ".todos-dedos-text"]
      }
    </script>

    <!-- LLM Description (AEO) -->
    <meta name="llm-description" content={data.seo.llm_descricao} />

    <!-- Injeção do Schema estruturado -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} is:inline />
    
    <!-- Google Tag Manager (Head) -->
    <GoogleTagManager />
  </head>
  <body>
    <!-- Google Tag Manager (Body NoScript) -->
    <GoogleTagManager bodyTag />
    
    <!-- Conteúdo da Página -->
    <slot />

    <!-- Script de Animação de Revelação de Scroll -->
    <script>
      // Função simples para animar elementos no scroll
      const reveals = document.querySelectorAll('.reveal');
      
      const revealOnScroll = () => {
        for (let i = 0; i < reveals.length; i++) {
          const windowHeight = window.innerHeight;
          const elementTop = reveals[i].getBoundingClientRect().top;
          const elementVisible = 120;
          
          if (elementTop < windowHeight - elementVisible) {
            reveals[i].classList.add('active');
          }
        }
      };

      // Executa no carregamento e no scroll
      window.addEventListener('scroll', revealOnScroll);
      window.addEventListener('load', revealOnScroll);
      revealOnScroll();
    </script>
  </body>
</html>
