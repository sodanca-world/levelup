---
interface VideoItem {
  id: string;
  titulo: string;
}

interface Props {
  introducao: string;
  videos: VideoItem[];
}

const { introducao, videos } = Astro.props;
---
<section class="videos-section">
  <div class="container">
    
    <!-- Introdução -->
    <div class="videos-intro reveal">
      <p class="intro-text">{introducao}</p>
    </div>

    <!-- Lista de Vídeos Sequenciais com Estilo Premium -->
    <div class="videos-list">
      {videos.map((video, index) => (
        <div class="video-card reveal">
          <div class="video-card-header">
            <span class="video-number">0{index + 1}</span>
            <h3 class="video-title">{video.titulo}</h3>
          </div>
          <div class="video-player-container">
            <div class="video-player-wrapper">
              <iframe 
                class="vimeo-iframe" 
                src={`https://player.vimeo.com/video/${video.id}?color=1cc6b2&title=0&byline=0&portrait=0`} 
                allow="autoplay; fullscreen; picture-in-picture" 
                allowfullscreen
              ></iframe>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .videos-section {
    padding: 80px 0;
    background-color: var(--color-bg-light);
  }

  .videos-intro {
    max-width: 800px;
    margin: 0 auto 60px auto;
    text-align: center;
  }

  .intro-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-primary-dark);
    font-weight: 500;
  }

  .videos-list {
    display: flex;
    flex-direction: column;
    gap: 50px;
    max-width: 900px;
    margin: 0 auto;
  }

  .video-card {
    background-color: var(--color-white);
    border-radius: 8px;
    padding: 30px;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    transition: var(--transition-smooth);
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-medium);
  }

  .video-card-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
    border-bottom: 1.5px solid var(--color-bg-light);
    padding-bottom: 15px;
  }

  .video-number {
    font-family: var(--font-title);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .video-title {
    font-family: var(--font-title);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.3;
  }

  /* Player de Vídeo Responsivo 16:9 */
  .video-player-container {
    width: 100%;
  }

  .video-player-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* Proporção 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: 6px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    background-color: #000;
  }

  .vimeo-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .videos-section {
      padding: 50px 0;
    }
    .video-card {
      padding: 20px;
    }
    .video-card-header {
      gap: 10px;
    }
    .video-number {
      font-size: 1.4rem;
    }
    .video-title {
      font-size: 1.15rem;
    }
  }
</style>
