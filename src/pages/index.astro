---
import siteData from '../data/siteData.json';
import '../styles/global.css';

const { menu_idiomas, configuracoes } = siteData;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Só Dança - Level Up Niveladores de Dedos</title>
    <meta name="description" content="Escolha seu idioma para conhecer os Niveladores e Extensores de Dedos Só Dança." />
    
    <!-- Favicon de destaque -->
    <link rel="icon" type="image/jpeg" href="/assets/images/Jose-Luis-1-100x100.jpg" />
    
    <!-- Meta tags AEO básicas -->
    <meta name="llm-description" content="Página oficial de seleção de idioma para os Niveladores e Extensores de Dedos Só Dança Level Up." />
    
    <!-- Script de Redirecionamento Inteligente -->
    <script is:inline>
      (function() {
        // Verifica se o usuário optou por desativar o redirecionamento automático
        const override = localStorage.getItem('sodanca_lang_override');
        if (override) return;

        // Detecta o idioma do navegador
        const lang = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
        
        let targetPath = '';
        if (lang.startsWith('pt')) {
          targetPath = '/portugues/';
        } else if (lang.startsWith('fr')) {
          targetPath = '/france/';
        } else if (lang.startsWith('it')) {
          targetPath = '/italia/';
        } else if (lang.startsWith('es')) {
          // Tenta diferenciar Espanha de América Latina
          if (lang.includes('es-es')) {
            targetPath = '/espanol/';
          } else {
            targetPath = '/latin-america/';
          }
        } else {
          targetPath = '/english/';
        }

        if (targetPath) {
          // Marca no localStorage que já foi feito o redirecionamento automático inicial
          localStorage.setItem('sodanca_lang_override', 'auto');
          window.location.href = targetPath;
        }
      })();
    </script>
  </head>
  <body>
    <main class="select-lang-section">
      <div class="bg-overlay"></div>
      
      <div class="select-container">
        <!-- Navegação de Idiomas no Topo Direito -->
        <header class="header-lang-nav">
          <div class="lang-grid-top reveal">
            {menu_idiomas.map((item) => (
              <a 
                href={item.path} 
                class="lang-top-pill"
                title={`Conheça em ${item.nome}`}
                onclick={`localStorage.setItem('sodanca_lang_override', '${item.id}')`}
              >
                <img src={`/assets/images/${item.image}`} alt={item.nome} />
              </a>
            ))}
          </div>
        </header>
        
        <!-- Conteúdo Central Esquerdo -->
        <div class="select-content-center reveal delay-2">
          <!-- Logotipo -->
          <div class="logo-main">
            <img src="/assets/images/Logo.png" alt="Só Dança Logo" class="logo-main-svg" />
          </div>
          
          <!-- Título estruturado conforme imagem de referência -->
          <div class="home-title-box">
            <h1 class="home-title-large">Level Up</h1>
            <div class="home-title-divider"></div>
            <h2 class="home-title-subtitle">Niveladores de Dedos</h2>
          </div>
        </div>

        <!-- Espaçador inferior invisível para manter o layout flex no lugar -->
        <div></div>
      </div>
    </main>

    <script>
      // Ativa as animações de revelação suave na home
      const reveals = document.querySelectorAll('.reveal');
      const revealOnLoad = () => {
        reveals.forEach(el => el.classList.add('active'));
      };
      window.addEventListener('load', revealOnLoad);
    </script>
  </body>
</html>
